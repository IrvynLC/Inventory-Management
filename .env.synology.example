POSTGRES_DB=inventory_management
POSTGRES_USER=inventory_app
POSTGRES_PASSWORD=replace-with-a-strong-database-password
IMS_PORT=3000

# Set to 1 only when the app is served through HTTPS/reverse proxy.
IMS_SECURE_COOKIES=0
IMS_SESSION_TTL_HOURS=12

# Set to 1 only if company policy allows short initial user passwords.
IMS_ALLOW_WEAK_SEEDED_PASSWORDS=1
